.toast-container {
  position: fixed;
  top: 200rpx;
  left: 50%;
  transform: translate(-50%, 0) scale(0);
  z-index: 3000;
  min-width: 400rpx;
  max-width: 600rpx;
  padding: 40rpx 60rpx;
  background: rgba(13, 13, 26, 0.95);
  backdrop-filter: blur(10px);
  border: 6rpx solid #FF3AF2;
  border-radius: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 0 40px rgba(255, 58, 242, 0.8), 8px 8px 0 #FFE600;
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.toast-container.show {
  transform: translate(-50%, 0) scale(1);
  opacity: 1;
}

.toast-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle, rgba(255, 58, 242, 0.1) 1px, transparent 1px);
  background-size: 20px 20px;
  border-radius: 48rpx;
  pointer-events: none;
}

.toast-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 900;
  color: #FFFFFF;
  border: 4rpx solid;
  position: relative;
  z-index: 1;
}

.toast-success .toast-icon {
  background: #00F5D4;
  border-color: #FFE600;
  box-shadow: 0 0 20px rgba(0, 245, 212, 0.6);
}

.toast-error .toast-icon {
  background: #FF6B35;
  border-color: #FF3AF2;
  box-shadow: 0 0 20px rgba(255, 107, 53, 0.6);
}

.toast-info .toast-icon {
  background: #7B2FFF;
  border-color: #00F5D4;
  box-shadow: 0 0 20px rgba(123, 47, 255, 0.6);
}

.toast-message {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-align: center;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
}
