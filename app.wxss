/* 极繁主义设计系统 - 全局样式 */
page {
  background: #0D0D1A;
  color: #FFFFFF;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  overflow-x: hidden;
}

/* 全局背景图案 */
page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle, #FF3AF2 1px, transparent 1px),
    repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255, 230, 0, 0.08) 10px, rgba(255, 230, 0, 0.08) 20px);
  background-size: 30px 30px, 40px 40px;
  pointer-events: none;
  z-index: 0;
  opacity: 0.6;
}

/* 动画定义 */
@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20px) rotate(5deg); }
}

@keyframes float-reverse {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(20px) rotate(-5deg); }
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 20px rgba(255, 58, 242, 0.5); }
  50% { box-shadow: 0 0 40px rgba(255, 58, 242, 0.8), 0 0 60px rgba(0, 245, 212, 0.5); }
}

@keyframes gradient-shift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes wiggle {
  0%, 100% { transform: rotate(-3deg); }
  50% { transform: rotate(3deg); }
}

@keyframes bounce-subtle {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

@keyframes spin-wheel {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 工具类 */
.animate-float { animation: float 6s ease-in-out infinite; }
.animate-float-reverse { animation: float-reverse 5s ease-in-out infinite; }
.animate-pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }
.animate-gradient-shift { animation: gradient-shift 4s ease infinite; }
.animate-spin-slow { animation: spin-slow 20s linear infinite; }
.animate-wiggle { animation: wiggle 1s ease-in-out infinite; }
.animate-bounce-subtle { animation: bounce-subtle 2s ease-in-out infinite; }

/* 文本阴影工具类 */
.text-shadow-double {
  text-shadow: 2px 2px 0px #7B2FFF, 4px 4px 0px #FF3AF2;
}

.text-shadow-triple {
  text-shadow: 2px 2px 0px #7B2FFF, 4px 4px 0px #FF3AF2, 6px 6px 0px #00F5D4;
}

.text-shadow-mega {
  text-shadow: 4px 4px 0px #7B2FFF, 8px 8px 0px #FF3AF2, 12px 12px 0px #00F5D4;
}

/* 盒子阴影工具类 */
.shadow-multi {
  box-shadow: 8px 8px 0 #FFE600, 16px 16px 0 #FF3AF2;
}

.shadow-multi-lg {
  box-shadow: 12px 12px 0 #00F5D4, 24px 24px 0 #FF3AF2, 36px 36px 0 #FFE600;
}

.glow-accent {
  box-shadow: 0 0 20px rgba(255, 58, 242, 0.5), 0 0 40px rgba(0, 245, 212, 0.3);
}

.glow-accent-lg {
  box-shadow: 0 0 40px rgba(255, 58, 242, 0.6), 0 0 80px rgba(255, 230, 0, 0.4), 0 0 120px rgba(123, 47, 255, 0.3);
}
